# Скопируй в .env и заполни: cp env.example .env
# Файл .env в git не попадает никогда. Пустой или фейковый ключ → громкий отказ на старте (fail-fast).

# GigaChat API — ключ авторизации (https://developers.sber.ru/gigachat)
GIGACHAT_CREDENTIALS=положи-сюда-authorization-key
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_BASE_URL=https://api.giga.chat/v1
# Цепочка сертификатов НУЦ Минцифры уже вшита в образы агентов (см. spec/05).
# Свой bundle при необходимости: GIGACHAT_CA_BUNDLE_FILE=/path/to/russian_trusted_ca.pem

# Инфраструктура (дефолты подходят для docker compose, менять не обязательно)
RABBITMQ_URL=amqp://agentarium:agentarium@rabbitmq:5672/
POSTGRES_DSN=postgresql://agentarium:agentarium@postgres:5432/agentarium
QDRANT_URL=http://qdrant:6333
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Целевая БД-«пациент» PoC — executor ходит в неё под read-only ролью
TARGET_DB_DSN=postgresql://readonly_auditor:readonly@target-db:5432/billing
