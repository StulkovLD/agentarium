# Скопируй в .env и заполни: cp env.example .env
# Файл .env в git не попадает никогда. Пустой или фейковый ключ → громкий отказ на старте (fail-fast).

# GigaChat API — ключ авторизации (https://developers.sber.ru/gigachat)
GIGACHAT_CREDENTIALS=положи-сюда-authorization-key
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Эндпоинт актуален с 17.07.2026 (сверено с документацией 19.07.2026);
# прежний https://gigachat.devices.sberbank.ru/api/v1 пока работает, но выводится из эксплуатации
GIGACHAT_BASE_URL=https://api.giga.chat/v1
# Цепочка сертификатов НУЦ Минцифры уже вшита в образы агентов и инструментов (seed, smoke) — см. spec/05.
# Свой bundle при необходимости: GIGACHAT_CA_BUNDLE_FILE=/path/to/russian_trusted_ca.pem

# Инфраструктура (дефолты подходят для docker compose, менять не обязательно)
RABBITMQ_URL=amqp://agentarium:agentarium@rabbitmq:5672/
POSTGRES_DSN=postgresql://agentarium:agentarium@postgres:5432/agentarium
QDRANT_URL=http://qdrant:6333
# Локальный эмбеддер bge-m3 (spec/05 слой 2): адрес Ollama-сервиса. Для контейнеров — compose-хост;
# хост-команды (make seed, тесты) перебивают на http://localhost:11434 (Makefile). Совпадает с
# base_url в блоке collections чертежа — переменная нужна, чтобы бить именно с хоста.
OLLAMA_BASE_URL=http://ollama:11434
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Целевая БД-«пациент» PoC — executor ходит в неё под read-only ролью (+ GRANT pg_monitor, см. spec/55)
TARGET_DB_DSN=postgresql://readonly_executor:readonly@target-db:5432/billing
