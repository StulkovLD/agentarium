%% Две конфигурации: маршруты и финал переключаются чертежом. Проекция спеков 40/55.
flowchart TB
    subgraph A[configs/dba-base.yaml — финал: plan.ready]
        a0([request.new]) --> a1[parser] --> a2[knowledge<br/>rag · regulations] --> a3[executor] --> a4([plan.ready → gateway ✓])
        a1 -.-> a5([request.rejected → gateway ✗])
    end

    subgraph B[configs/dba-extended.yaml — финал: audit.done; ядро и старые агенты не тронуты]
        b0([request.new]) --> b1[parser] --> b2[knowledge<br/>rag · regulations] --> b3[executor]
        b3 --> b4([plan.ready — уже не финал])
        b4 --> b5[auditor<br/>новый тип · incidents]
        b5 --> b6([audit.done → gateway ✓])
        b1 -.-> b7([request.rejected → gateway ✗])
    end
